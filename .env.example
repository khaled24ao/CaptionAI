# Groq API Key for AI-powered image captioning
GROQ_API_KEY=your_api_key_here

# Application settings
DEBUG=False

# Server settings
APP_NAME=CaptionAI
MAX_FILE_SIZE_MB=5
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
UPLOAD_FOLDER=storage/uploads
CORS_ORIGINS=*

# Flask settings
FLASK_ENV=production
FLASK_DEBUG=0
